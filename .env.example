# --- Database (Neon Postgres) ---
# Get from https://console.neon.tech/  (use the pooled connection string for runtime)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.neon.tech/neondb?sslmode=require"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# In production set to your domain, e.g. https://intranet.heritagelab.ca
AUTH_URL="http://localhost:3000"
# Trust the X-Forwarded-Host on Vercel
AUTH_TRUST_HOST="true"

# --- (No separate auth provider creds needed) ---
# Magic-link sign-in is sent via the same Resend account configured below
# under RESEND_API_KEY / MAIL_FROM.

# --- Access control ---
# Comma-separated list of email domains permitted to sign in.
# Defaults to heritagelab.ca if unset. Case-insensitive.
ALLOWED_EMAIL_DOMAINS="heritagelab.ca"
# Optional extra individual emails outside those domains (e.g. board members on personal Gmail).
# Leave blank if not needed.
ALLOWED_EMAILS=""

# --- Resend (transactional email) ---
# https://resend.com/api-keys
RESEND_API_KEY=""
# Verified sender domain. Until heritagelab.ca is verified in Resend, use onboarding@resend.dev for testing.
MAIL_FROM="Heritage Lab Intranet <intranet@heritagelab.ca>"
# Where travel claims are sent
CLAIMS_RECIPIENT="payments@heritagelab.ca"
